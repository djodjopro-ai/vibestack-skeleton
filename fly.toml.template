# Template — platform rewrites {{APP_NAME}} and {{REGION}} per tenant
app = "{{APP_NAME}}"
primary_region = "{{REGION}}"

[build]

[env]
  PORT = "8080"
  DATABASE_URL = "sqlite:///data/vibestack.db"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 0

[[mounts]]
  source = "vibestack_data"
  destination = "/data"
  initial_size = "1gb"

[[vm]]
  cpu_kind = "shared"
  cpus = 1
  memory_mb = 512
